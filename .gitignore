# === Medallion layers：data 不入庫，只追 .gitkeep + 目錄結構 ===
bronze/**
silver/**
gold/**
reference/**
catalog/**
meta/**
_staging/**
_quarantine/**

# .gitkeep 例外
!bronze/.gitkeep
!silver/.gitkeep
!gold/.gitkeep
!reference/.gitkeep
!catalog/.gitkeep
!meta/.gitkeep
!_staging/.gitkeep
!**/.gitkeep

# Reference 內小型 seed (yaml/json) + 編譯後 parquet 例外
!reference/*.yaml
!reference/*.yml
!reference/*.json
!reference/*.parquet
!reference/seeds/
!reference/seeds/**

# 保留 audit manifest 與 inventory baseline（小檔，反正只進不出）
!meta/
!meta/audit/
!meta/audit/*.csv
!meta/audit/*.jsonl
!_quarantine/
!_quarantine/manifest_*.jsonl

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
